# Biến môi trường cho DAS Backend
# Copy file này thành .env và chỉnh sửa theo cấu hình của bạn

# Database PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/das_db
DATABASE_URL_SYNC=postgresql://postgres:123456@localhost:5432/das_db

# JWT Secret Key
SECRET_KEY=das-super-secret-key-2026-betterus-system
REFRESH_SECRET_KEY=das-refresh-super-secret-key-2026-betterus-system
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=DAS Backend
APP_VERSION=1.0.0
DEBUG=True
